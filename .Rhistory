I_amp     = 150,  # pA/cm^2
t1_start  = 50,   # démarre à 50 ms
duration = 10,   # 10 ms
interval  = 100,  # 100 ms entre les pulses
tmax      = 250
)
## ---------- Cas 2 : intervalle = 60 ms ----------
