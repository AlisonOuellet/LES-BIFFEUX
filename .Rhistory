}
return(out)
}
run_sim <- function(V1_val, Ka_val, Ki_val, times) {
p <- params
p["V1"] <- V1_val
p["Ka"] <- Ka_val
p["Ki"] <- Ki_val
ode(y = y0, times = times, func = cascade_MAPK_fb, parms = p)
}
