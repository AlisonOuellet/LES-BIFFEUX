# ii- Analyse de Bootstrap (1000 itérations) [cite: 57]
run_boot <- function(d_mat, model_name) {
tree_nj <- nj(d_mat)
boot_res <- boot.phylo(tree_nj, dna_mat,
function(x) nj(dist.dna(x, model = model_name)),
B = 1000)
return(list(tree = tree_nj, boot = boot_res))
}
cat("Calcul des bootstraps en cours...\n")
res_JC   <- run_boot(dist_JC,   "JC69")
res_K80  <- run_boot(dist_K80,  "K80")
res_TN93 <- run_boot(dist_TN93, "TN93")
# Matrices de distances (Ajout de pairwise.deletion = TRUE pour éviter les NA)
dist_JC   <- dist.dna(dna_mat, model = "JC69", pairwise.deletion = TRUE)
dist_K80  <- dist.dna(dna_mat, model = "K80",  pairwise.deletion = TRUE)
dist_TN93 <- dist.dna(dna_mat, model = "TN93", pairwise.deletion = TRUE)
dist_GG95 <- dist.dna(dna_mat, model = "GG95", pairwise.deletion = TRUE)
# ii- Analyse de Bootstrap (1000 itérations) corrigée
run_boot <- function(d_mat, model_name) {
# On utilise njs() au lieu de nj() pour l'arbre de base
tree_njs <- njs(d_mat)
# Bootstrap avec njs() et pairwise.deletion
boot_res <- boot.phylo(tree_njs, dna_mat,
function(x) {
d <- dist.dna(x, model = model_name, pairwise.deletion = TRUE)
njs(d) # njs tolère les valeurs manquantes (NA)
},
B = 1000)
return(list(tree = tree_njs, boot = boot_res))
}
cat("Calcul des bootstraps en cours (cela peut prendre quelques minutes)...\n")
res_JC   <- run_boot(dist_JC,   "JC69")
res_K80  <- run_boot(dist_K80,  "K80")
res_TN93 <- run_boot(dist_TN93, "TN93")
res_GG95 <- run_boot(dist_GG95, "GG95")
# ii- Analyse de Bootstrap (1000 itérations) corrigée
# ii- Analyse de Bootstrap (1000 itérations) corrigée
run_boot <- function(d_mat, model_name) {
# Sécurisation de la matrice de base
d_m_base <- as.matrix(d_mat)
d_m_base[is.na(d_m_base) | is.nan(d_m_base) | is.infinite(d_m_base)] <- 10
tree_base <- unroot(nj(as.dist(d_m_base))) # unroot() sécurise la topologie
# Bootstrap avec correction à la volée
boot_res <- boot.phylo(tree_base, dna_mat,
function(x) {
# 1. Calcul de la distance
d <- dist.dna(x, model = model_name, pairwise.deletion = TRUE)
d_m <- as.matrix(d)
# 2. Remplacement des valeurs problématiques par 10
d_m[is.na(d_m) | is.nan(d_m) | is.infinite(d_m)] <- 10
# 3. Retourne l'arbre sans racine
return(unroot(nj(as.dist(d_m))))
},
B = 1000,
quiet = FALSE) # Laisse FALSE pour voir la progression
return(list(tree = tree_base, boot = boot_res))
}
cat("\nReprise des bootstraps (1000 itérations)...\n")
res_JC   <- run_boot(dist_JC,   "JC69")
res_K80  <- run_boot(dist_K80,  "K80")
res_TN93 <- run_boot(dist_TN93, "TN93")
res_GG95 <- run_boot(dist_GG95, "GG95")
# iii- Recherche du modèle maximisant la robustesse [cite: 58]
avg_boot <- c(JC = mean(res_JC$boot), K80 = mean(res_K80$boot),
TN93 = mean(res_TN93$boot), GG95 = mean(res_GG95$boot))
cat("\nMoyenne des scores de bootstrap par modèle :\n")
print(avg_boot)
# iv- Passage à phangorn : modelTest() [cite: 59]
