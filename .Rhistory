# Construction arbre NJ
tree_nj <- NJ(dist_aa)
# Bootstrap NJ
bs <- bootstrap.phyDat(phy_data, FUN=function(xx) NJ(dist.ml(xx, model=model)), bs=1000)
# Stocker les résultats
results[[paste(frame_name, model, sep="_")]] <- list(tree=tree_nj, bootstrap=bs)
# Affichage arbre avec supports
plot(tree_nj, main=paste("NJ -", model, "-", frame_name), cex=0.8)
nodelabels(bs)
# Calculer la robustesse moyenne
mean_bs <- mean(bs, na.rm=TRUE)
cat("Robustesse moyenne bootstrap:", mean_bs, "\n")
}
}
aa_data_1 <- phyDat(as.matrix(aa_alignment_1), type = "AA")
aa_data_2 <- phyDat(as.matrix(aa_alignment_2), type = "AA")
# 1. Préparation des données (on transforme en format phangorn)
# Assumons que aa_alignment_1 est le "choisi" et aa_alignment_2 est le "modifié"
aa_data_1 <- phyDat(as.matrix(aa_alignment_1), type = "AA")
aa_data_2 <- phyDat(as.matrix(aa_alignment_2), type = "AA")
# 2. Calcul des matrices de distances (Modèles : LG, JTT, Blosum62)
# Note : phangorn utilise dist.ml ou dist.p for protein distances
models <- c("LG", "JTT", "Blosum62")
calculate_aa_trees <- function(data, label) {
cat("\n--- Analyse pour :", label, "---\n")
# On boucle sur les modèles pour générer les arbres NJ
trees <- list()
for(m in models) {
# Calcul de la distance spécifique au modèle
# dist.ml est plus robuste pour les modèles AA complexes
d <- dist.ml(data, model = m)
tr <- nj(d)
# Bootstrap (100 itérations ici pour la rapidité, mettez 1000 pour votre travail)
cat("Calcul Bootstrap pour", m, "...\n")
bp <- boot.phylo(tr, as.matrix(data), function(x) nj(dist.ml(as.phyDat(x), model = m)), B = 100)
# Stockage
trees[[m]] <- list(tree = tr, bootstrap = bp)
cat("Moyenne BS pour", m, ":", mean(bp, na.rm = TRUE), "\n")
}
return(trees)
}
# Exécution pour les deux cadres de lecture
results_frame1 <- calculate_aa_trees(aa_data_1, "Cadre de lecture 1")
results_frame2 <- calculate_aa_trees(aa_data_2, "Cadre de lecture 2")
# 1. Préparation des données (on transforme en format phangorn)
# Assumons que aa_alignment_1 est le "choisi" et aa_alignment_2 est le "modifié"
aa_data_1 <- phyDat(as.matrix(aa_alignment_1), type = "AA")
# Choisir l'alignement à tester : cadre de lecture 1 et cadre modifié 2
aa_alignments <- list(
frame1 = aa_alignment_1,
frame2 = aa_alignment_2
)
# Modèles d'évolution des protéines
aa_models <- c("LG", "JTT", "BLOSUM62")
# Conversion en phyDat (phangorn)
aa_phy <- lapply(aa_alignments, function(x) phyDat(as.matrix(x), type="AA"))
# Liste pour stocker les résultats
results <- list()
par(mfrow = c(2, 3), mar = c(2, 2, 4, 1))
for (frame_name in names(aa_phy)) {
phy_data <- aa_phy[[frame_name]]
for (model in aa_models) {
cat("\n--- Frame:", frame_name, "- Model:", model, "---\n")
# Calcul de distance selon le modèle choisi
dist_aa <- dist.ml(phy_data, model = model)
# Construction arbre NJ
tree_nj <- NJ(dist_aa)
# Bootstrap NJ
bs <- bootstrap.phyDat(phy_data, FUN=function(xx) NJ(dist.ml(xx, model=model)), bs=1000)
# Stocker les résultats
results[[paste(frame_name, model, sep="_")]] <- list(tree=tree_nj, bootstrap=bs)
# Affichage arbre avec supports
plot(tree_nj, main=paste("NJ -", model, "-", frame_name), cex=0.8)
nodelabels(bs)
# Calculer la robustesse moyenne
mean_bs <- mean(bs, na.rm=TRUE)
cat("Robustesse moyenne bootstrap:", mean_bs, "\n")
}
}
# Conversion en phyDat (phangorn)
aa_phy <- lapply(aa_alignments, function(x) phyDat(as.matrix(x), type="AA"))
# Liste pour stocker les résultats
results <- list()
par(mfrow = c(2, 3), mar = c(2, 2, 4, 1))
for (frame_name in names(aa_phy)) {
phy_data <- aa_phy[[frame_name]]
for (model in aa_models) {
cat("\n--- Frame:", frame_name, "- Model:", model, "---\n")
# Calcul de la distance et de l'arbre initial
dist_aa <- dist.ml(phy_data, model = model)
tree_nj <- NJ(dist_aa)
# BOOTSTRAP CORRIGÉ
# On utilise bootstrap.phyDat qui est nativement conçu pour les objets phyDat
# Note : bs=100 pour tester rapidement, remontez à 1000 pour le travail final
bs_trees <- bootstrap.phyDat(phy_data,
FUN = function(x) NJ(dist.ml(x, model = model)),
bs = 100)
# Calcul des fréquences de support sur l'arbre original
# plotBS ou prop.clades permettent de récupérer les valeurs
bs_values <- plotBS(tree_nj, bs_trees, type = "none") # "none" pour ne pas dessiner tout de suite
# Stockage
results[[paste(frame_name, model, sep="_")]] <- list(tree = tree_nj, bootstrap = bs_values)
# Affichage de l'arbre avec les supports
plot(tree_nj, main=paste("NJ -", model, "-", frame_name), cex=0.8)
nodelabels(tree_nj$node.label, cex=0.7, adj=c(1.2, -0.5), frame="n")
# Calculer la robustesse moyenne (en ignorant la racine si nécessaire)
# Les supports sont stockés dans tree_nj$node.label par plotBS
mean_bs <- mean(as.numeric(tree_nj$node.label), na.rm=TRUE)
cat("Robustesse moyenne bootstrap:", mean_bs, "%\n")
}
}
# Modèles d'évolution des protéines
aa_models <- c("LG", "JTT", "Blosum62")
results <- list()
par(mfrow = c(2, 3), mar = c(2, 2, 4, 1))
for (frame_name in names(aa_phy)) {
phy_data <- aa_phy[[frame_name]]
for (model in aa_models) {
cat("\n--- Frame:", frame_name, "- Model:", model, "---\n")
# Calcul de la distance et de l'arbre initial
dist_aa <- dist.ml(phy_data, model = model)
tree_nj <- NJ(dist_aa)
# BOOTSTRAP CORRIGÉ
# On utilise bootstrap.phyDat qui est nativement conçu pour les objets phyDat
# Note : bs=100 pour tester rapidement, remontez à 1000 pour le travail final
bs_trees <- bootstrap.phyDat(phy_data,
FUN = function(x) NJ(dist.ml(x, model = model)),
bs = 100)
# Calcul des fréquences de support sur l'arbre original
# plotBS ou prop.clades permettent de récupérer les valeurs
bs_values <- plotBS(tree_nj, bs_trees, type = "none") # "none" pour ne pas dessiner tout de suite
# Stockage
results[[paste(frame_name, model, sep="_")]] <- list(tree = tree_nj, bootstrap = bs_values)
# Affichage de l'arbre avec les supports
plot(tree_nj, main=paste("NJ -", model, "-", frame_name), cex=0.8)
nodelabels(tree_nj$node.label, cex=0.7, adj=c(1.2, -0.5), frame="n")
# Calculer la robustesse moyenne (en ignorant la racine si nécessaire)
# Les supports sont stockés dans tree_nj$node.label par plotBS
mean_bs <- mean(as.numeric(tree_nj$node.label), na.rm=TRUE)
cat("Robustesse moyenne bootstrap:", mean_bs, "%\n")
}
}
for (frame_name in names(aa_phy)) {
phy_data <- aa_phy[[frame_name]]
for (model in aa_models) {
cat("\n--- Frame:", frame_name, "- Model:", model, "---\n")
# Calcul distance et arbre
dist_aa <- dist.ml(phy_data, model = model)
tree_nj <- NJ(dist_aa)
# Bootstrap (Remettre bs=1000 pour le rapport final)
bs_trees <- bootstrap.phyDat(phy_data,
FUN = function(x) NJ(dist.ml(x, model = model)),
bs = 10)
# Intégrer les valeurs de bootstrap à l'arbre original
# p = 0 permet de garder tous les labels pour le calcul de la moyenne
tree_with_bs <- plotBS(tree_nj, bs_trees, type = "none", p = 0)
# Stockage
results[[paste(frame_name, model, sep="_")]] <- tree_with_bs
# Affichage
plot(tree_with_bs, main=paste("NJ -", model, "-", frame_name), cex=0.8)
# Calcul de la moyenne robuste
# On extrait les labels, on retire les vides, on convertit en chiffre
boot_values <- as.numeric(tree_with_bs$node.label)
mean_bs <- mean(boot_values, na.rm = TRUE)
cat("Robustesse moyenne bootstrap:", round(mean_bs, 2), "%\n")
}
}
# Synthèse des résultats
cat("\n--- RÉSUMÉ DE LA ROBUSTESSE ---\n")
df_summary <- data.frame(
Analyse = names(results_aa),
Mean_Bootstrap = sapply(results_aa, function(x) x$mean_bs)
)
df_summary <- data.frame(
Analyse = names(results),
Mean_Bootstrap = sapply(results, function(x) x$mean_bs)
)
# --- RÉSUMÉ DE LA ROBUSTESSE ---
cat("\n--- RÉSUMÉ DE LA ROBUSTESSE ---\n")
# Création d'un data.frame à partir de la liste 'results'
df_summary <- data.frame(
Analyse = names(results),
Mean_Bootstrap = sapply(results, function(x) {
valeurs <- as.numeric(x$node.label)
mean(valeurs, na.rm = TRUE)
})
)
print(df_summary)
# Trouver le gagnant pour le cadre 1 (les 3 premières lignes)
best_model_idx <- which.max(df_summary$Mean_Bootstrap[1:3])
cat("\nModèle le plus robuste (Frame 1) :", df_summary$Analyse[best_model_idx], "\n")
# 1. Création des 3 cadres de lecture (Nucléotides)
dna_frames <- list(
frame1 = seqs,
frame2 = subseq(seqs, start = 2),
frame3 = subseq(seqs, start = 3)
)
results_ml_frames <- list()
# Boucle sur les 3 cadres
for (f_name in names(dna_frames)) {
cat("\n\n=== ANALYSE :", f_name, "===\n")
# Alignement et conversion
aln <- AlignSeqs(dna_frames[[f_name]], verbose = FALSE)
phy_dat <- phyDat(as.matrix(aln), type = "DNA")
# i- Trouver le meilleur modèle avec modelTest()
cat("Recherche du meilleur modèle...\n")
mt <- modelTest(phy_dat)
best_mod <- mt$Model[which.min(mt$AICc)]
cat("Meilleur modèle (AICc) pour", f_name, ":", best_mod, "\n")
# ii- Reconstruction ML avec le modèle trouvé
# On part d'un arbre NJ pour l'optimisation
tree_init <- nj(dist.dna(as.DNAbin(phy_dat), model = "TN93"))
fit <- pml(tree_init, data = phy_dat)
# Mise à jour du modèle selon modelTest (on simplifie vers le modèle de base)
# parse_model est une simplification, on utilise souvent GTR ou le modèle spécifique
fit_opt <- optim.pml(fit, model = "GTR", optInv = TRUE, optGamma = TRUE)
# Bootstrap ML (1000 itérations)
cat("Calcul du Bootstrap ML (1000 itérations)...\n")
bs_ml <- bootstrap.pml(fit_opt, bs = 1000, optInv = TRUE, optGamma = TRUE)
# Sauvegarde et affichage
results_ml_frames[[f_name]] <- list(fit = fit_opt, bs = bs_ml, model = best_mod)
plotBS(fit_opt$tree, bs_ml, main = paste("ML Tree -", f_name, "-", best_mod))
}
