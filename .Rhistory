library(ape)
library(Biostrings)
# Importation des données
data <- readDNAStringSet("Cetacea COI.fasta")
# Alignement
aligned_data <- AlignSeqs(data)
# Retire les gaps de l'alignement pour retrouver les séquences brutes
sequences_brutes <- RemoveGaps(aligned_data)
# Alignement avec les pénalités à zéro
aligned_no_gap <- AlignSeqs(sequences_brutes, gapOpening = 0, gapExtension = 0)
# Visualiser l'alignement dans un browser (optionnel)
BrowseSeqs(aligned_no_gap, highlight = 0)
# Sauvegarde l'alignement final
writeXStringSet(aligned_no_gap, "aligned_sequences.fasta")
# Traduction avec code mitochondrial vertébré
aligned_dna <- AlignTranslation(data,
readingFrame = 1,
geneticCode = getGeneticCode("2"),
type = "DNAStringSet")
# Pour visualiser l'alignement en AA
aligned_aa_1 <- AlignTranslation(data,
readingFrame = 1,
geneticCode = getGeneticCode("2"),
type = "AAStringSet")
# Test le cadre de lecture 2
aligned_aa_2 <- AlignTranslation(data,
readingFrame = 2,
geneticCode = getGeneticCode("2"),
type = "AAStringSet")
# Traduction (Frame 1)
dna_bin <- as.DNAbin(aligned_data)
# i- Matrices de distances avec modèles évolutifs [cite: 56]
dist_JC   <- dist.dna(dna_bin, model = "JC69") # Jukes & Cantor
dist_K80  <- dist.dna(dna_bin, model = "K80")  # Kimura 2 paramètres
dist_TN93 <- dist.dna(dna_bin, model = "TN93") # Tamura & Nei
dist_GG92 <- dist.dna(dna_bin, model = "GG92") # Galtier & Gouy (1992)
# ii- Analyse de Bootstrap (1000 itérations) pour chaque modèle [cite: 57]
# Fonction pour automatiser le bootstrap NJ
run_boot <- function(d_mat, model_name) {
tree_nj <- nj(d_mat)
boot_res <- boot.phylo(tree_nj, dna_bin,
function(x) nj(dist.dna(x, model = model_name)),
B = 1000)
return(list(tree = tree_nj, boot = boot_res))
}
res_JC   <- run_boot(dist_JC,   "JC69")
res_K80  <- run_boot(dist_K80,  "K80")
res_TN93 <- run_boot(dist_TN93, "TN93")
res_GG92 <- run_boot(dist_GG92, "GG92")
# iii- Recherche du modèle maximisant la robustesse [cite: 58]
# Calculer la moyenne des valeurs de bootstrap pour chaque arbre
avg_boot <- c(JC = mean(res_JC$boot), K80 = mean(res_K80$boot),
TN93 = mean(res_TN93$boot), GG92 = mean(res_GG92$boot))
print(avg_boot) # Le score maximum indique le modèle le plus robuste [cite: 58]
# iv- Passage à phangorn : modelTest() [cite: 59]
dna_phyDat <- as.phyDat(aln_default)
mt <- modelTest(dna_phyDat)
print(mt) # Chercher le modèle avec le BIC le plus bas
# v- Extraction des paramètres et reconstruction [cite: 60, 61]
# Supposons que le meilleur modèle soit GTR+G+I (exemple courant)
best_model_info <- mt[which.min(mt$BIC), ]
alpha_gamma <- best_model_info$shape # Paramètre Gamma [cite: 60]
p_inv <- best_model_info$inv         # Sites invariants (I) [cite: 60]
# Reconstruction finale (Optimisation par maximum de vraisemblance)
fit_init <- pml(res_TN93$tree, data = dna_phyDat)
fit_optim <- optim.pml(fit_init, model = "GTR", # À ajuster selon modelTest
optGamma = TRUE, optInv = TRUE,
rearrangement = "stochastic")
# Visualisation finale avec racine (Groupe externe : Pinnipèdes) [cite: 48]
# Remplace "gi|5835009" par l'ID exact du Phoque gris dans ton fichier
plot(root(fit_optim$tree, outgroup = "gi|5835009:6249-7793", resolve.root = TRUE),
main = paste("Arbre final optimisé :", best_model_info$Model))
# Traduction (Frame 1)
