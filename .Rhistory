params_23 <- params
params_23["Ka"] <- 0
params_23["Ki"] <- 0.1
params_23["V1"] <- 2.5
times_osc <- seq(0, 5000, by = 1)
out_osc <- ode(y = y0, times = times_osc, func = cascade_MAPK, parms = params_23)
## ---------- Trace les oscillations de MAPK-PP ----------
plot(out_osc[,"time"], out_osc[,"MAPK_PP"], type = "l", lwd = 2,
xlab = "Temps (s)",
ylab = "[MAPK-PP] (nM)",
col = "darkgreen",
main = "Oscillations de MAPK-PP (Ka=0, Ki=0.1, V1=2.5)")
## ---------- Cherche les maxima locaux de MAPK-PP ----------
MAPKPP <- out_osc[,"MAPK_PP"]
time   <- out_osc[,"time"]
# Indices des maxima (avec une petite marge : point où le gradient change de signe)
d1 <- diff(MAPKPP)
sign_change <- diff(sign(d1))  # -2 aux maxima (passage + -> -)
max_indices <- which(sign_change == -2) + 1  # +1 pour revenir à l’indice de MAPKPP
# Garde que les derniers maxima (après la phase transitoire)
valid <- which(time[max_indices] > 1000)
max_indices <- max_indices[valid]
# S'il y a au moins deux maxima, on calcule la période moyenne
if (length(max_indices) >= 2) {
peak_times <- time[max_indices]
periods    <- diff(peak_times)
periode_moyenne <- mean(periods)
cat("\nPériode moyenne des oscillations ≈",
round(periode_moyenne, 2), "s\n")
} else {
cat("\nPas assez de pics détectés pour calculer une période fiable.\n")
}
library(deSolve)
params <- c(
C     = 20,    # µF/cm^2
gCa  = 4,     # mS/cm^2
gK   = 8,     # mS/cm^2
gL   = 2,     # mS/cm^2
ECa  = 120,   # mV
EK   = -84,   # mV
EL   = -60,   # mV
## Paramètres des fonctions m_inf et w_inf
Vm          = -1.2,  # mV
theta_m     = 18,    # mV
Vw          = 2,     # mV
theta_w     = 30,    # mV
tau_w       = 12
)
## ---------- Fonctions d’activation ----------
m_inf <- function(V, p) {
with(as.list(p),
0.5 * (1 + tanh((V - Vm)/theta_m)))
}
w_inf <- function(V, p) {
with(as.list(p),
0.5 * (1 + tanh((V - Vw)/theta_w)))
}
## ---------- Courant appliqué (modifiable) ----------
I_app <- function(t){
0
}
## ---------- Équations différentielles du modèle Morris-Lecar ----------
morris_lecar <- function(t, y, p) {
with(as.list(c(y, p)), {
# Courant appliqué au temps t
I_app <- I_app_fonction(t)
# Fonctions d’activation
m_inf_ <- m_inf(V, p)
w_inf_ <- w_inf(V, p)
# Équations
dV <- (1/C) * (
gCa * m_inf_ * (ECa - V) +
gK  * w    * (EK  - V) +
gL         * (EL  - V) +
I_app
)
dw <- (w_inf_ - w) / tau_w
list(c(dV, dw))
})
}
## ---------- Conditions initiales ----------
V0 <- -60  # mV (potentiel de repos approx.)
w0 <- w_inf(V0, params)
y0 <- c(V = V0, w = w0)
sim_two_pulses <- function(I_amp, t1_start, duration, interval, tmax) {
t2_start <- t1_start + duration + interval
## On (re)définit la fonction du courant appliqué
I_app_fonction <<- function(t) {
cond1 <- (t >= t1_start) & (t < t1_start + duration)
cond2 <- (t >= t2_start) & (t < t2_start + duration)
I_amp * (cond1 | cond2)
}
times <- seq(0, tmax, by = 0.05)
out <- ode(y0, times, morris_lecar, params)
as.data.frame(out)
}
## ---------- Cas 1 : intervalle = 100 ms (contrôle) ----------
